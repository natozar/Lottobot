rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: own data only, admin can read all
    // Plan fields (plano, planoExpira, planoCiclo, mpSubscriptionId, planoHistorico)
    // can only be written by Cloud Functions (admin SDK)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['plano', 'planoExpira', 'planoCiclo', 'mpSubscriptionId', 'planoHistorico']);
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      match /savedGames/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Draws: read-only for clients
    match /draws/{drawId} {
      allow read: if request.auth != null;
    }

    // Blog posts: readable by all (SSR function reads via admin SDK anyway)
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if false;
    }

    // Config: readable by all auth users, writable by admin
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Notifications: admin only
    match /notifications/{id} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Bets odds: readable by all auth users, writable only by Cloud Functions
    match /bets_odds/{sportKey} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Bets meta: readable by admin only
    match /bets_meta/{doc} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      allow write: if false;
    }
  }
}
